rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidUser(data) {
      return data.nickname is string && data.nickname.size() >= 3
        && data.nickname.size() <= 20
        && data.car is string;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'adm@motoristafinancas.com'
      );
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isAdmin();
    }

    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidId(transactionId);
      allow update, delete: if isOwner(userId) || isAdmin();
    }

    match /ranking/{userId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }
  }
}
