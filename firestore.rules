rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidUser(data) {
      return data.nickname is string && data.nickname.size() >= 3
        && data.nickname.size() <= 20
        && data.name is string
        && data.car is string
        && (data.carType == 'Combustão' || data.carType == 'Elétrico');
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
    }

    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(transactionId);
      allow update, delete: if isOwner(userId);
    }

    match /ranking/{userId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow write: if isOwner(userId) && isValidId(userId);
    }
  }
}
